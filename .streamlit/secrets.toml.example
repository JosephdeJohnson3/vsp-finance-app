# Copy this file's structure into Streamlit Cloud's "Secrets" box (Advanced settings,
# when deploying) or into a local .streamlit/secrets.toml for testing on your own
# machine. Never commit a real secrets.toml to GitHub — only this .example file.

app_password = "choose-a-shared-password-here"
sheet_id = "paste-the-long-id-from-your-google-sheet-url-here"

[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "paste-from-downloaded-json"
private_key = "-----BEGIN PRIVATE KEY-----\npaste the whole key from the JSON file here, keep the \\n exactly as they appear\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account-name@your-project-id.iam.gserviceaccount.com"
client_id = "paste-from-downloaded-json"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "paste-from-downloaded-json"
universe_domain = "googleapis.com"

# Optional — only needed for the Leads page (Reddit lead finder).
# Create a free "script" app at reddit.com/prefs/apps (see README).
[reddit]
client_id = "paste-the-client-id-under-your-app-name"
client_secret = "paste-the-secret"
user_agent = "vsp-leads by u/your_reddit_username"
